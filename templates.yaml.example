# Template configuration for convert_markdown_to_doc tool.
#
# Each template references a Google Doc whose named styles (heading fonts,
# body font, sizes, colors, line spacing) are extracted and applied to
# newly created documents.
#
# Place this file at ~/.config/google-docs-mcp/templates.yaml
# and mount it read-only into the container.

templates:
  - name: "standard"
    doc_id: "YOUR_TEMPLATE_DOC_ID_HERE"
    default: true

  # Add more templates as needed:
  # - name: "report"
  #   doc_id: "ANOTHER_TEMPLATE_DOC_ID"
  #   default: false
